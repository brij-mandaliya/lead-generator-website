#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/lib/google-sheets/node_modules/uuid/node_modules:/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/lib/google-sheets/node_modules:/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/lib/google-sheets/node_modules/uuid/node_modules:/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/lib/google-sheets/node_modules:/home/brij.mandliya/Documents/data document/BRIJ_MANDALIYA/Lead-Generator-Website/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../uuid/dist/bin/uuid" "$@"
else
  exec node  "$basedir/../uuid/dist/bin/uuid" "$@"
fi
