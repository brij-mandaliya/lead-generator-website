# Copy this file to `.env` and adjust values before running `docker compose up`.
# Anything left at its default is fine for local development.

# ── API Database Connection ───────────────────────────────────────────
DB_HOST=
DB_USER=
DB_PASS=
DB_DATABASE=
DB_PORT=

# ── Auth ──────────────────────────────────────────────────────────────
SESSION_SECRET=dev-secret-key-change-me-in-production

# ── Frontend ──────────────────────────────────────────────────────────
# Path the SPA is served from. Use "/" for the default setup; change
# to "/leadforge/" etc. if you reverse-proxy this app under a subpath.
BASE_PATH=/
FRONTEND_PORT=80

# ── Demo data ────────────────────────────────────────────────────────
# Set to "true" to seed the demo admin (admin@leadforge.app / admin123)
# and demo user (demo@leadforge.app / demo123) on first boot. Leave
# "false" in production.
SEED_DEMO_DATA=false

# ── Google OAuth Configuration ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
FRONTEND_URL=

# ── Razorpay Configuration ────────────────────────────────────────────
# Razorpay environment (test or live)
RAZORPAY_ENVIRONMENT=test

# Razorpay test credentials (use actual test credentials from Razorpay dashboard)
RAZORPAY_KEY_ID_TEST=rzp_test_1234567890
RAZORPAY_KEY_SECRET_TEST=your_test_key_secret_here
RAZORPAY_WEBHOOK_SECRET_TEST=your_test_webhook_secret_here

# Razorpay live credentials (leave empty for development)
RAZORPAY_KEY_ID_LIVE=
RAZORPAY_KEY_SECRET_LIVE=
RAZORPAY_WEBHOOK_SECRET_LIVE=

# ── Google Sheets Service Account ─────────────────────────────────────
# Service account email and key JSON for creating/sharing Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── SMTP / Email Configuration ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Lead Generator <noreply@leadgenerator.app>
